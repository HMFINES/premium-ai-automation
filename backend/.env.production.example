NODE_ENV=production
PORT=4000

DB_HOST=your-mysql-host
DB_PORT=3306
DB_USER=your-db-user
DB_PASSWORD=your-db-password
DB_NAME=elevatex
DB_CONNECTION_LIMIT=10

# Use long random values (min 32 chars)
JWT_ACCESS_SECRET=replace_with_strong_random_secret_min_32_chars
JWT_REFRESH_SECRET=replace_with_another_strong_random_secret_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Comma-separated list is supported
FRONTEND_ORIGIN=https://www.elevatex.com,https://elevatex.com
OAUTH_STATE_TTL_MS=600000

# Leave blank to disable provider login
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://www.elevatex.com/api/auth/google/callback

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=https://www.elevatex.com/api/auth/github/callback

# Optional: without this, chatbot uses fallback support responses
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=450
OPENAI_TEMPERATURE=0.6
